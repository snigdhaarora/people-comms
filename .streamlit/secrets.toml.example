# ─────────────────────────────────────────────────────────────────
# Streamlit Cloud Secrets — TEMPLATE
# ─────────────────────────────────────────────────────────────────
# Copy this file's contents into:
#   Streamlit Cloud → Your app → Settings → Secrets
# OR rename to secrets.toml (this file is safe to commit; secrets.toml is NOT)
# ─────────────────────────────────────────────────────────────────

# Slack Bot Token (xoxb-...)
# Get from: https://api.slack.com/apps → OAuth & Permissions → Bot User OAuth Token
SLACK_TOKEN = ""

# WhatsApp (Meta Cloud API)
# Get from: Meta Business Suite → WhatsApp → API Setup
WA_TOKEN    = ""
WA_PHONE_ID = ""

# Email / SMTP
# For Gmail: enable 2FA → Google Account → Security → App Passwords → generate one
SMTP_PASSWORD = ""
